---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="max-w-md mx-auto p-6 mt-10">
    <h1 class="text-2xl font-bold mb-6 text-center">Iniciar Sesión</h1>

    <form id="form-login" class="flex flex-col gap-4 bg-gray-50 p-6 rounded-md border border-gray-200">
      <div class="flex flex-col gap-1">
        <label for="email" class="text-sm font-medium text-gray-700">Email:</label>
        <input 
          type="email" 
          id="email" 
          required 
          class="border border-gray-300 rounded p-2"
          placeholder="tu@email.com"
        />
      </div>

      <div class="flex flex-col gap-1">
        <label for="password" class="text-sm font-medium text-gray-700">Contraseña:</label>
        <input 
          type="password" 
          id="password" 
          required 
          class="border border-gray-300 rounded p-2"
          placeholder="••••••••"
        />
      </div>

      <button type="submit" class="bg-blue-600 text-white font-semibold py-2 rounded hover:bg-blue-700 transition mt-2">
        Entrar
      </button>

      <p id="mensaje-error" class="text-sm font-medium text-red-600 hidden mt-2"></p>
    </form>
  </main>
</Layout>

<script>
  //Importa la conexion con supabase
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('form-login') as HTMLFormElement;
  const mensajeError = document.getElementById('mensaje-error') as HTMLParagraphElement;
  //Si hay formulario ejecuta el condicional
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      //Lee el email y la contraseña
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const passwordInput = document.getElementById('password') as HTMLInputElement;

      //Llamamos a Supabase para iniciar sesión
      const { data, error } = await supabase.auth.signInWithPassword({
        //El .value equivale al valor del email o contraseña en supabase
        email: emailInput.value,    
        password: passwordInput.value,
      });

      if (error) {
        mensajeError.textContent = "Error: " + "Credenciales invalidas";
        mensajeError.style.display = "block";
      } else {
        //Si el login es exitoso, redirigimos a la página principal
        window.location.href = '/alumnos';
      }
    });
  }
</script>

